.tenpai-page {
  padding-top: 32rpx;
}

.intro-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  border-color: rgba(15, 83, 66, 0.24);
  background: linear-gradient(180deg, #ffffff 0%, #f8fbf7 100%);
}

.intro-copy {
  min-width: 0;
}

.page-title {
  color: var(--felt-deep);
  font-size: 42rpx;
  font-weight: 700;
}

.page-desc {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.mode-switch {
  display: flex;
  flex: 0 0 auto;
  gap: 8rpx;
  padding: 6rpx;
  border: 2rpx solid var(--ivory-edge);
  border-radius: 16rpx;
  background: #fdfcf8;
}

.mode-pill {
  width: 92rpx !important;
  min-height: 60rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  background: transparent;
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 60rpx;
}

.mode-pill.active {
  background: var(--felt);
  color: var(--ivory);
}

.section-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.hand-actions {
  display: flex;
  flex: 0 0 auto;
  gap: 12rpx;
}

.section-title {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 700;
}

.section-hint {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.tile-scroll {
  width: 100%;
  padding: 4rpx 0 12rpx;
  white-space: nowrap;
}

.tile-strip {
  display: inline-flex;
  min-height: 92rpx;
  gap: 8rpx;
  align-items: center;
}

.selected-tile {
  flex: 0 0 auto;
  padding: 6rpx;
  border-radius: 12rpx;
  background: #fdfcf8;
  border: 1rpx solid var(--ivory-edge);
}

.selected-tile:active {
  background: #eef4f0;
  border-color: var(--felt);
}

.strip-empty {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.progress-line {
  margin: 8rpx 0 20rpx;
  color: var(--felt);
  font-size: 27rpx;
  font-weight: 700;
}

.result-panel {
  border-color: rgba(15, 83, 66, 0.2);
}

.result-title {
  color: var(--felt-deep);
  font-size: 36rpx;
  font-weight: 800;
}

.result-empty .result-title,
.result-error .result-title {
  color: var(--red);
}

.result-hint {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.5;
}

.result-error .result-hint {
  color: var(--red);
}

.wait-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.wait-item {
  display: flex;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  background: #fdfcf8;
}

.wait-count {
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.2;
}

.draw-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.draw-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx;
  border: 1rpx solid var(--line);
  border-radius: 12rpx;
  background: #fdfcf8;
}

.draw-tile {
  flex: 0 0 auto;
  padding-right: 12rpx;
  border-right: 1rpx solid var(--line);
}

.draw-detail {
  display: flex;
  min-width: 0;
  flex: 1 1 auto;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.draw-waits {
  display: flex;
  min-width: 0;
  flex: 1 1 auto;
  flex-wrap: wrap;
  gap: 6rpx;
}

.draw-count {
  flex: 0 0 auto;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.2;
}
