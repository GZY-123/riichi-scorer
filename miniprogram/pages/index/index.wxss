.index-page {
  padding-top: 64rpx;
}

.hero {
  margin-bottom: 40rpx;
  padding: 0 8rpx;
}

.title {
  color: var(--felt-deep);
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 朱红一点，如「中」牌 */
.title-dot {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  margin-left: 8rpx;
  border-radius: 4rpx;
  background: var(--red);
}

.subtitle {
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 27rpx;
}

.text-link {
  width: fit-content !important;
  min-height: 48rpx;
  margin: 18rpx 0 0 !important;
  padding: 0;
  background: transparent;
  color: var(--felt);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: left;
}

.profile-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.profile-state {
  color: var(--muted);
  font-size: 24rpx;
}

.profile-head-actions {
  display: flex;
  flex: 0 0 auto;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  justify-content: flex-end;
}

.profile-summary,
.profile-editor {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
}

.profile-editor {
  flex-wrap: wrap;
}

.profile-avatar,
.avatar-picker {
  width: 104rpx !important;
  height: 104rpx;
  flex: 0 0 104rpx;
  border-radius: 50%;
  overflow: hidden;
  box-sizing: border-box;
}

.avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 104rpx;
  margin: 0;
  padding: 0;
  border: 2rpx solid var(--ivory-edge);
  background: #fdfcf8;
  line-height: 1;
}

.avatar-picker[disabled] {
  opacity: 0.72;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
  font-size: 40rpx;
  font-weight: 700;
}

.profile-name {
  min-width: 0;
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nickname-input {
  flex: 1;
  min-width: 360rpx;
}

.profile-actions {
  width: 100%;
}

.rejoin-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  border-color: rgba(184, 134, 44, 0.36);
}

.rejoin-copy {
  min-width: 0;
}

.rejoin-room {
  color: var(--felt-deep);
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
  line-height: 1.1;
}

.rejoin-side {
  display: flex;
  flex: 0 0 208rpx;
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
}

.rejoin-mode {
  align-self: flex-end;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 700;
}

.rejoin-button {
  min-height: 88rpx;
  font-size: 28rpx;
  line-height: 88rpx;
}

.mode-group {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mode-option {
  display: flex;
  gap: 16rpx;
  align-items: center;
  min-height: 112rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  background: #fdfcf8;
}

.mode-option.active {
  border-color: var(--felt);
  background: #f0f5ef;
}

.mode-title {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.mode-desc {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.rules-panel {
  margin: 4rpx 0 24rpx;
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  background: #fdfcf8;
  overflow: hidden;
}

.rules-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100% !important;
  min-height: 96rpx;
  margin: 0 !important;
  padding: 18rpx 24rpx;
  background: transparent;
  color: var(--ink);
  line-height: 1.35;
  text-align: left;
}

.rules-title {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
}

.rules-summary {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.rules-toggle-icon {
  flex: 0 0 auto;
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 700;
}

.rules-body {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 20rpx 24rpx 24rpx;
  border-top: 1rpx solid var(--line);
}

.rule-row,
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.rule-label {
  flex: 0 0 auto;
  white-space: nowrap;
  color: var(--ink);
  font-size: 25rpx;
  font-weight: 600;
}

.segment-group {
  display: flex;
  flex: 0 0 auto;
  overflow: hidden;
  border: 2rpx solid var(--line);
  border-radius: 10rpx;
}

.segment-button {
  width: auto !important;
  flex: 0 0 auto;
  min-width: 112rpx;
  min-height: 64rpx;
  margin: 0 !important;
  padding: 0 20rpx;
  border-radius: 0;
  background: #ffffff;
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.segment-button.active {
  background: var(--felt);
  color: #ffffff;
}

.rule-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

/* 开关每项独占一行，与「顺位马」行式一致，三麻多一项也不挤 */
.switch-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8rpx;
}

.rule-field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rule-input {
  min-height: 76rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.picker-value {
  min-width: 176rpx;
  min-height: 64rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--line);
  border-radius: 10rpx;
  background: #ffffff;
  color: var(--felt-deep);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

.switch-row {
  min-height: 64rpx;
}

.create-button,
.join-button {
  margin-top: 24rpx;
}

.room-code-input {
  letter-spacing: 6rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  font-feature-settings: "tnum";
}
