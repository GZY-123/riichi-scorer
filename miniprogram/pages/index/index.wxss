.index-page {
  padding-top: 72rpx;
}

.hero {
  margin-bottom: 36rpx;
}

.title {
  color: #17322d;
  font-size: 46rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 10rpx;
  color: #6a7672;
  font-size: 28rpx;
}

.mode-group {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.mode-option {
  display: flex;
  gap: 18rpx;
  align-items: center;
  min-height: 104rpx;
  padding: 0 20rpx;
  border: 1rpx solid #d9e3df;
  border-radius: 8rpx;
  background: #fbfcfb;
}

.mode-option.active {
  border-color: #176b5b;
  background: #edf7f3;
}

.mode-title {
  color: #17211f;
  font-size: 30rpx;
  font-weight: 600;
}

.mode-desc {
  margin-top: 6rpx;
  color: #72807b;
  font-size: 24rpx;
}

.create-button,
.join-button {
  margin-top: 24rpx;
}

.room-code-input {
  letter-spacing: 0;
}
