<view class="page index-page">
  <view class="hero">
    <view class="title">立直麻将记分<text class="title-dot"></text></view>
    <view class="subtitle">三麻 / 四麻 · 房间码同桌实时记分</view>
    <button class="text-link" bindtap="onYakuReferenceTap">查看役种表</button>
  </view>

  <view class="section panel profile-panel">
    <view class="profile-head">
      <view>
        <view class="label">个人资料</view>
        <view class="profile-state">{{profileSaved && !editingProfile ? "已登录" : "填写后进入房间"}}</view>
      </view>
      <view wx:if="{{profileSaved && !editingProfile}}" class="profile-head-actions">
        <button class="mini-button" bindtap="onHistoryTap">对局记录</button>
        <button class="mini-button" bindtap="onTenpaiTap">听牌计算</button>
        <button class="mini-button" bindtap="onEditProfile">修改</button>
      </view>
    </view>

    <view wx:if="{{profileSaved && !editingProfile}}" class="profile-summary">
      <image
        wx:if="{{avatarFileId}}"
        class="profile-avatar"
        src="{{avatarFileId}}"
        mode="aspectFill"
      />
      <view wx:else class="profile-avatar avatar-fallback">{{avatarText}}</view>
      <view class="profile-name">{{nickName}}</view>
    </view>

    <view wx:else class="profile-editor">
      <button
        class="avatar-picker"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
        disabled="{{uploadingAvatar}}"
      >
        <image
          wx:if="{{avatarPreview || avatarFileId}}"
          class="profile-avatar"
          src="{{avatarPreview || avatarFileId}}"
          mode="aspectFill"
        />
        <text wx:else class="profile-avatar avatar-fallback">{{avatarText}}</text>
      </button>
      <input
        class="input nickname-input"
        type="nickname"
        maxlength="16"
        placeholder="输入你的昵称"
        value="{{nickName}}"
        bindinput="onNickNameInput"
      />
      <view class="button-row profile-actions">
        <button
          class="primary-button"
          loading="{{savingProfile}}"
          disabled="{{savingProfile || uploadingAvatar}}"
          bindtap="onSaveProfile"
        >
          保存资料
        </button>
        <button
          wx:if="{{profileSaved}}"
          class="ghost-button"
          bindtap="onCancelProfileEdit"
        >
          取消
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{lastRoom}}" class="section panel rejoin-panel">
    <view class="rejoin-copy">
      <view class="label">进行中的对局</view>
      <view class="rejoin-room num">{{lastRoom.roomCode}}</view>
    </view>
    <view class="rejoin-side">
      <view class="rejoin-mode">{{lastRoom.mode === "3p" ? "三麻" : "四麻"}}</view>
      <button class="primary-button rejoin-button" bindtap="onContinueRoom">继续对局</button>
    </view>
  </view>

  <view class="section panel">
    <view class="label">创建房间</view>
    <radio-group class="mode-group" bindchange="onModeChange">
      <label class="mode-option {{mode === '4p' ? 'active' : ''}}">
        <radio value="4p" checked="{{mode === '4p'}}" color="#176b5b" />
        <view>
          <view class="mode-title">四麻</view>
          <view class="mode-desc">4 人，默认 25000 点</view>
        </view>
      </label>
      <label class="mode-option {{mode === '3p' ? 'active' : ''}}">
        <radio value="3p" checked="{{mode === '3p'}}" color="#176b5b" />
        <view>
          <view class="mode-title">三麻</view>
          <view class="mode-desc">3 人，默认 35000 点</view>
        </view>
      </label>
    </radio-group>
    <view class="rules-panel">
      <button class="rules-toggle" bindtap="onRulesToggle">
        <view>
          <view class="rules-title">对局规则</view>
          <view class="rules-summary">{{rulesSummary}}</view>
        </view>
        <view class="rules-toggle-icon">{{rulesExpanded ? "收起" : "展开"}}</view>
      </button>
      <view wx:if="{{rulesExpanded}}" class="rules-body">
        <view class="rule-row">
          <view class="rule-label">局数</view>
          <view class="segment-group">
            <button
              class="segment-button {{rules.length === 'east' ? 'active' : ''}}"
              data-length="east"
              bindtap="onRuleLengthTap"
            >
              东风
            </button>
            <button
              class="segment-button {{rules.length === 'hanchan' ? 'active' : ''}}"
              data-length="hanchan"
              bindtap="onRuleLengthTap"
            >
              半庄
            </button>
          </view>
        </view>
        <view class="rule-grid">
          <label class="rule-field">
            <text class="rule-label">起始点</text>
            <input
              class="input rule-input num"
              type="number"
              value="{{rules.startScore}}"
              bindinput="onRuleStartScoreInput"
            />
          </label>
          <label class="rule-field">
            <text class="rule-label">返点</text>
            <input
              class="input rule-input num"
              type="number"
              value="{{rules.returnScore}}"
              bindinput="onRuleReturnScoreInput"
            />
          </label>
        </view>
        <view class="rule-row">
          <view class="rule-label">顺位马</view>
          <picker
            mode="selector"
            range="{{umaOptionLabels}}"
            value="{{umaIndex}}"
            bindchange="onUmaChange"
          >
            <view class="picker-value">{{umaOptionLabels[umaIndex]}}</view>
          </picker>
        </view>
        <view class="switch-grid">
          <label class="switch-row">
            <text class="rule-label">击飞</text>
            <switch checked="{{rules.tobi}}" color="#176b5b" data-key="tobi" bindchange="onRuleSwitchChange" />
          </label>
          <label class="switch-row">
            <text class="rule-label">切上满贯</text>
            <switch
              checked="{{rules.kiriageMangan}}"
              color="#176b5b"
              data-key="kiriageMangan"
              bindchange="onRuleSwitchChange"
            />
          </label>
          <label wx:if="{{mode === '3p'}}" class="switch-row">
            <text class="rule-label">自摸损</text>
            <switch
              checked="{{rules.tsumoLoss}}"
              color="#176b5b"
              data-key="tsumoLoss"
              bindchange="onRuleSwitchChange"
            />
          </label>
        </view>
      </view>
    </view>
    <button class="primary-button create-button" loading="{{creating}}" bindtap="onCreateRoom">
      创建房间
    </button>
  </view>

  <view class="section panel">
    <label class="label">加入房间</label>
    <input
      class="input room-code-input"
      maxlength="6"
      type="number"
      placeholder="输入 6 位房间码"
      value="{{roomCode}}"
      bindinput="onRoomCodeInput"
    />
    <button class="secondary-button join-button" loading="{{joining}}" bindtap="onJoinRoom">
      加入房间
    </button>
  </view>
</view>
