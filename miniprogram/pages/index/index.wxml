<view class="page index-page">
  <view class="hero">
    <view class="title">立直麻将记分<text class="title-dot"></text></view>
    <view class="subtitle">三麻 / 四麻 · 房间码同桌实时记分</view>
  </view>

  <view class="section panel profile-panel">
    <view class="profile-head">
      <view>
        <view class="label">个人资料</view>
        <view class="profile-state">{{profileSaved && !editingProfile ? "已登录" : "填写后进入房间"}}</view>
      </view>
      <view wx:if="{{profileSaved && !editingProfile}}" class="profile-head-actions">
        <button class="mini-button" bindtap="onHistoryTap">对局记录</button>
        <button class="mini-button" bindtap="onEditProfile">修改</button>
      </view>
    </view>

    <view wx:if="{{profileSaved && !editingProfile}}" class="profile-summary">
      <image
        wx:if="{{avatarFileId}}"
        class="profile-avatar"
        src="{{avatarFileId}}"
        mode="aspectFill"
      />
      <view wx:else class="profile-avatar avatar-fallback">{{avatarText}}</view>
      <view class="profile-name">{{nickName}}</view>
    </view>

    <view wx:else class="profile-editor">
      <button
        class="avatar-picker"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
        disabled="{{uploadingAvatar}}"
      >
        <image
          wx:if="{{avatarPreview || avatarFileId}}"
          class="profile-avatar"
          src="{{avatarPreview || avatarFileId}}"
          mode="aspectFill"
        />
        <text wx:else class="profile-avatar avatar-fallback">{{avatarText}}</text>
      </button>
      <input
        class="input nickname-input"
        type="nickname"
        maxlength="16"
        placeholder="输入你的昵称"
        value="{{nickName}}"
        bindinput="onNickNameInput"
      />
      <view class="button-row profile-actions">
        <button
          class="primary-button"
          loading="{{savingProfile}}"
          disabled="{{savingProfile || uploadingAvatar}}"
          bindtap="onSaveProfile"
        >
          保存资料
        </button>
        <button
          wx:if="{{profileSaved}}"
          class="ghost-button"
          bindtap="onCancelProfileEdit"
        >
          取消
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{lastRoom}}" class="section panel rejoin-panel">
    <view class="rejoin-copy">
      <view class="label">进行中的对局</view>
      <view class="rejoin-room num">{{lastRoom.roomCode}}</view>
    </view>
    <view class="rejoin-side">
      <view class="rejoin-mode">{{lastRoom.mode === "3p" ? "三麻" : "四麻"}}</view>
      <button class="primary-button rejoin-button" bindtap="onContinueRoom">继续对局</button>
    </view>
  </view>

  <view class="section panel">
    <view class="label">创建房间</view>
    <radio-group class="mode-group" bindchange="onModeChange">
      <label class="mode-option {{mode === '4p' ? 'active' : ''}}">
        <radio value="4p" checked="{{mode === '4p'}}" color="#176b5b" />
        <view>
          <view class="mode-title">四麻</view>
          <view class="mode-desc">4 人，初始 25000 点</view>
        </view>
      </label>
      <label class="mode-option {{mode === '3p' ? 'active' : ''}}">
        <radio value="3p" checked="{{mode === '3p'}}" color="#176b5b" />
        <view>
          <view class="mode-title">三麻</view>
          <view class="mode-desc">3 人，初始 35000 点</view>
        </view>
      </label>
    </radio-group>
    <button class="primary-button create-button" loading="{{creating}}" bindtap="onCreateRoom">
      创建房间
    </button>
  </view>

  <view class="section panel">
    <label class="label">加入房间</label>
    <input
      class="input room-code-input"
      maxlength="6"
      type="number"
      placeholder="输入 6 位房间码"
      value="{{roomCode}}"
      bindinput="onRoomCodeInput"
    />
    <button class="secondary-button join-button" loading="{{joining}}" bindtap="onJoinRoom">
      加入房间
    </button>
  </view>
</view>
