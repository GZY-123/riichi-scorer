<view class="page settlement-page">
  <view class="panel summary">
    <view>
      <view class="title">终局结算</view>
      <view class="subtitle">房间 {{roomCode || "------"}}</view>
    </view>
    <view class="status">{{statusText}}</view>
  </view>

  <view class="section panel">
    <view class="section-title">顺位</view>
    <view wx:if="{{rankings.length === 0}}" class="empty">暂无玩家数据</view>
    <block wx:for="{{rankings}}" wx:key="openid">
      <view class="rank-row {{item.rankClass}}">
        <view class="rank-no">{{item.rank}}</view>
        <image
          wx:if="{{item.avatarFileId}}"
          class="rank-avatar"
          src="{{item.avatarFileId}}"
          mode="aspectFill"
        />
        <view wx:else class="rank-avatar avatar-fallback">{{item.avatarText}}</view>
        <view class="rank-main">
          <view class="rank-name">{{item.nickName}}</view>
          <view class="rank-note">{{item.seatText}}起家</view>
        </view>
        <view class="rank-score">
          <view class="final-score num {{item.scoreClass}}">{{item.finalScoreText}}</view>
          <view class="raw-score num">素点 {{item.rawScore}}</view>
        </view>
      </view>
    </block>
  </view>

  <view class="button-row settlement-actions">
    <button class="secondary-button" bindtap="onHistoryDetailTap">查看牌谱</button>
    <button class="primary-button" bindtap="onReturnHomeTap">返回首页</button>
  </view>
</view>
