.summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title {
  color: var(--felt-deep);
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.status {
  padding: 8rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 600;
}

.section-title {
  margin-bottom: 8rpx;
  color: var(--ink);
  font-size: 31rpx;
  font-weight: 700;
}

.rank-row {
  display: grid;
  grid-template-columns: 64rpx 64rpx minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
  min-height: 120rpx;
  border-top: 1rpx solid var(--line);
}

.rank-row:first-of-type {
  border-top: none;
}

.rank-no {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid var(--line);
  background: #fdfcf8;
  color: var(--muted);
  font-size: 28rpx;
  font-weight: 700;
}

.rank-row.rank-1 {
  grid-template-columns: 72rpx 80rpx minmax(0, 1fr) auto;
  min-height: 144rpx;
}

.rank-row.rank-1 .rank-no {
  width: 64rpx;
  height: 64rpx;
  border-color: var(--gold);
  background: var(--gold);
  color: var(--ivory);
}

.rank-row.rank-2 .rank-no {
  border-color: var(--silver);
  background: var(--silver);
  color: #ffffff;
}

.rank-row.rank-3 .rank-no {
  border-color: var(--bronze);
  background: var(--bronze);
  color: #ffffff;
}

.rank-avatar {
  width: 56rpx;
  height: 56rpx;
  overflow: hidden;
  border-radius: 50%;
  background: rgba(15, 83, 66, 0.1);
  box-sizing: border-box;
}

.rank-row.rank-1 .rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid var(--gold);
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 700;
}

.rank-name {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-note {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.rank-score {
  text-align: right;
}

.final-score {
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 700;
}

.rank-row.rank-1 .final-score {
  font-size: 44rpx;
  font-weight: 800;
}

.score-positive {
  color: var(--felt);
}

.score-negative {
  color: var(--red);
}

.score-neutral {
  color: var(--muted);
}

.raw-score {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.return-home-button {
  margin-top: 32rpx;
}
