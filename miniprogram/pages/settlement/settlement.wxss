.summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.title {
  color: var(--felt-deep);
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 26rpx;
}

.status {
  padding: 8rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 600;
}

.section-title {
  margin-bottom: 8rpx;
  color: var(--ink);
  font-size: 31rpx;
  font-weight: 700;
}

.rank-row {
  display: grid;
  grid-template-columns: 72rpx 1fr auto;
  gap: 20rpx;
  align-items: center;
  min-height: 118rpx;
  border-top: 1rpx solid var(--line);
}

.rank-row:first-of-type {
  border-top: none;
}

.rank-no {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid var(--line);
  background: #fdfcf8;
  color: var(--muted);
  font-size: 28rpx;
  font-weight: 700;
}

.rank-no.first {
  border-color: var(--felt);
  background: var(--felt);
  color: var(--ivory);
}

.rank-name {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-note {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.rank-score {
  text-align: right;
}

.final-score {
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 700;
}

.raw-score {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 22rpx;
}
