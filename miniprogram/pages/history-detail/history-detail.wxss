.history-detail-page {
  padding-top: 32rpx;
}

.summary-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.room-code {
  color: var(--felt-deep);
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  line-height: 1.15;
}

.summary-meta {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 25rpx;
}

.status-chip {
  flex: 0 0 auto;
  padding: 8rpx 20rpx;
  border-radius: 26rpx;
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 700;
}

.section-title {
  margin-bottom: 12rpx;
  color: var(--ink);
  font-size: 31rpx;
  font-weight: 700;
}

.score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 104rpx;
  border-top: 1rpx solid var(--line);
}

.score-row:first-of-type {
  border-top: none;
}

.player-identity {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.player-avatar {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 56rpx;
  overflow: hidden;
  border-radius: 50%;
  background: rgba(15, 83, 66, 0.1);
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 700;
}

.player-main {
  min-width: 0;
}

.player-name {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-seat {
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.player-score {
  flex: 0 0 auto;
  color: var(--felt-deep);
  font-size: 34rpx;
  font-weight: 800;
}

.timeline-item {
  position: relative;
  display: grid;
  grid-template-columns: 28rpx minmax(0, 1fr);
  gap: 16rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(31, 43, 39, 0.08);
}

.timeline-item:first-of-type {
  border-top: none;
}

.timeline-item::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 13rpx;
  width: 2rpx;
  background: rgba(15, 83, 66, 0.14);
  content: "";
}

.timeline-dot {
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  margin-top: 14rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: var(--felt);
  box-shadow: 0 0 0 2rpx rgba(15, 83, 66, 0.16);
}

.timeline-main {
  min-width: 0;
}

.event-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.round-chip,
.event-type {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.round-chip {
  background: #f0f5ef;
  color: var(--felt);
}

.event-type {
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
}

.event-type.t-riichi {
  background: rgba(185, 58, 40, 0.1);
  color: var(--red);
}

.event-type.t-draw,
.event-type.t-undo {
  background: rgba(110, 123, 118, 0.12);
  color: var(--muted);
}

.event-type.t-finish {
  background: rgba(185, 58, 40, 0.12);
  color: var(--red);
}

.event-time {
  margin-left: auto;
  color: var(--muted);
  font-size: 22rpx;
}

.event-actor {
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 29rpx;
  font-weight: 700;
}

.event-deltas,
.event-note {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.45;
}

.event-note {
  color: #7b6b4c;
}

.hand-record {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--line);
}

.tile-strip,
.meld-tiles {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  align-items: center;
}

.record-tile {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx;
  border-radius: 8rpx;
  background: rgba(15, 83, 66, 0.05);
}

.record-tile.winning {
  box-shadow: inset 0 0 0 3rpx var(--red);
}

.winning-mark {
  position: absolute;
  right: 4rpx;
  bottom: 2rpx;
  color: var(--red);
  font-size: 16rpx;
  font-weight: 800;
}

.meld-list,
.yaku-list,
.score-text {
  margin-top: 16rpx;
}

.meld-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 60rpx;
}

.meld-row + .meld-row,
.yaku-row + .yaku-row {
  border-top: 1rpx solid rgba(31, 43, 39, 0.06);
}

.meld-type {
  flex: 0 0 auto;
  color: var(--felt);
  font-size: 25rpx;
  font-weight: 700;
}

.meld-tiles {
  justify-content: flex-end;
}

.yaku-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 58rpx;
  color: var(--ink);
  font-size: 26rpx;
}

.yaku-value {
  flex: 0 0 auto;
  color: var(--felt);
  font-weight: 700;
}

.score-text {
  color: var(--felt-deep);
  font-size: 30rpx;
  font-weight: 800;
}
