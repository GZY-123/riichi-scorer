/* 房间页 = 牌桌：毡绿桌面上摆象牙白的牌 */
page {
  background: radial-gradient(circle at 50% 10%, #14614d 0%, #0f5342 48%, #0a3d31 100%);
}

.room-page {
  padding-bottom: 56rpx;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
  padding: 8rpx 4rpx 0;
}

.room-label {
  color: rgba(251, 248, 239, 0.62);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.room-code {
  margin-top: 6rpx;
  color: var(--ivory);
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 10rpx;
  line-height: 1.1;
}

.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.round-chip {
  padding: 8rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(251, 248, 239, 0.14);
  border: 1rpx solid rgba(251, 248, 239, 0.22);
  color: var(--ivory);
  font-size: 26rpx;
  font-weight: 600;
}

.sync-state {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: rgba(251, 248, 239, 0.66);
  font-size: 22rpx;
}

.sync-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6fdc9f;
}

/* 玩家分数卡：象牙白「牌」 */
.score-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.player-card {
  min-height: 180rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #fdfbf4 0%, #f3edda 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
    0 6rpx 14rpx rgba(6, 32, 25, 0.35);
  box-sizing: border-box;
}

.player-card.dealer {
  box-shadow:
    inset 0 0 0 3rpx var(--amber),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
    0 6rpx 14rpx rgba(6, 32, 25, 0.35);
}

.player-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.player-identity {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.player-avatar,
.event-avatar {
  flex: 0 0 auto;
  overflow: hidden;
  border-radius: 50%;
  background: rgba(15, 83, 66, 0.1);
}

.player-avatar {
  width: 56rpx;
  height: 56rpx;
  border: 2rpx solid rgba(15, 83, 66, 0.12);
}

.event-avatar {
  width: 40rpx;
  height: 40rpx;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--felt);
  font-size: 24rpx;
  font-weight: 700;
}

.event-avatar.avatar-fallback {
  font-size: 20rpx;
}

.seat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: var(--felt);
  color: var(--ivory);
  font-size: 26rpx;
  font-weight: 700;
}

.dealer-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--amber);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.player-name {
  margin-top: 18rpx;
  color: var(--muted);
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score {
  margin-top: 6rpx;
  color: var(--ink);
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.15;
}

/* 供托与状态：毡面上的暗色槽 */
.round-panel {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(6, 32, 25, 0.35);
  border: 1rpx solid rgba(251, 248, 239, 0.12);
}

.round-stat {
  min-width: 0;
}

.stat-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: rgba(251, 248, 239, 0.6);
  font-size: 23rpx;
}

.stick-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.stick-dot.red {
  background: #e05a44;
}

.stick-dot.amber {
  background: #d9a84e;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  color: var(--ivory);
  font-size: 32rpx;
  font-weight: 700;
}

/* 操作区：和牌是「牌面」白键，其余为毡面暗键 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.felt-main,
.felt-sub,
.felt-ghost,
.finish-button {
  width: 100% !important;
  min-height: 96rpx;
  margin: 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 96rpx;
  box-sizing: border-box;
}

.felt-main {
  background: linear-gradient(180deg, #fdfbf4 0%, #f1ead5 100%);
  color: var(--felt-deep);
  font-weight: 700;
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
    0 6rpx 14rpx rgba(6, 32, 25, 0.35);
}

.felt-main:active {
  background: #ece4cc;
}

.felt-sub {
  background: rgba(251, 248, 239, 0.14);
  border: 1rpx solid rgba(251, 248, 239, 0.26);
  color: var(--ivory);
  line-height: 94rpx;
}

.felt-sub:active {
  background: rgba(251, 248, 239, 0.24);
}

.felt-ghost {
  background: transparent;
  border: 1rpx solid rgba(251, 248, 239, 0.2);
  color: rgba(251, 248, 239, 0.72);
  line-height: 94rpx;
}

.finish-button {
  background: rgba(6, 32, 25, 0.3);
  border: 2rpx solid rgba(224, 90, 68, 0.8);
  color: #f2a496;
  line-height: 92rpx;
}

.finish-button:active {
  background: rgba(185, 58, 40, 0.3);
}

/* 事件履历：象牙白面板 */
.room-page .panel {
  background: var(--ivory);
  border: none;
  box-shadow: 0 6rpx 14rpx rgba(6, 32, 25, 0.28);
}

.section-title {
  color: var(--ink);
  font-size: 31rpx;
  font-weight: 700;
}

.event-item {
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(31, 43, 39, 0.08);
}

.event-item:first-of-type {
  margin-top: 16rpx;
}

.event-main {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.event-type {
  flex: 0 0 auto;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(15, 83, 66, 0.1);
  color: var(--felt);
  font-size: 23rpx;
  font-weight: 700;
}

.event-type.t-riichi {
  background: rgba(185, 58, 40, 0.1);
  color: var(--red);
}

.event-type.t-draw {
  background: rgba(110, 123, 118, 0.12);
  color: var(--muted);
}

.event-type.t-undo {
  background: rgba(110, 123, 118, 0.12);
  color: var(--muted);
}

.event-type.t-finish {
  background: rgba(185, 58, 40, 0.12);
  color: var(--red);
}

.event-actor {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 600;
}

.event-time {
  flex: 0 0 auto;
  color: var(--muted);
  font-size: 22rpx;
}

.event-deltas {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 25rpx;
}

/* 记分弹层 */
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  display: flex;
  align-items: flex-end;
  background: rgba(6, 20, 16, 0.55);
}

.event-panel {
  width: 100%;
  max-height: 88vh;
  overflow: auto;
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.panel-title {
  margin-bottom: 20rpx;
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
}

.delta-row,
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  min-height: 92rpx;
  border-top: 1rpx solid #f0ede1;
}

.delta-player {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 600;
}

.delta-hint {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.delta-input,
.small-input {
  width: 190rpx;
  min-height: 76rpx;
  padding: 0 18rpx;
  border: 1rpx solid var(--ivory-edge);
  border-radius: 12rpx;
  background: #fdfcf8;
  text-align: right;
  box-sizing: border-box;
  font-feature-settings: "tnum";
}

.note-input {
  width: 100%;
  height: 110rpx;
  min-height: 0;
  margin-top: 20rpx;
  padding: 18rpx;
  border: 1rpx solid var(--ivory-edge);
  border-radius: 12rpx;
  background: #fdfcf8;
  box-sizing: border-box;
}

.panel-actions {
  margin-top: 28rpx;
}
