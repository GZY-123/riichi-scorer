<view class="page room-page">
  <view class="room-header">
    <view>
      <view class="room-label">房间码</view>
      <view class="room-code num">{{roomCode || "------"}}</view>
    </view>
    <view class="header-right">
      <view class="round-chip">{{roundText}}</view>
      <view class="sync-state"><text class="sync-dot"></text>{{watchState}}</view>
    </view>
  </view>

  <view class="score-grid section">
    <block wx:for="{{players}}" wx:key="openid">
      <view class="player-card {{item.isDealer ? 'dealer' : ''}}">
        <view class="player-top">
          <view class="player-identity">
            <image
              wx:if="{{item.avatarFileId}}"
              class="player-avatar"
              src="{{item.avatarFileId}}"
              mode="aspectFill"
            />
            <view wx:else class="player-avatar avatar-fallback">{{item.avatarText}}</view>
            <text class="seat">{{item.seatText}}</text>
          </view>
          <text wx:if="{{item.isDealer}}" class="dealer-badge">庄</text>
        </view>
        <view class="player-name">{{item.nickName}}</view>
        <view class="score num">{{item.score}}</view>
      </view>
    </block>
  </view>

  <view class="section round-panel">
    <view class="round-stat">
      <text class="stat-label"><text class="stick-dot red"></text>立直棒</text>
      <text class="stat-value num">{{riichiSticks}}</text>
    </view>
    <view class="round-stat">
      <text class="stat-label"><text class="stick-dot amber"></text>本场棒</text>
      <text class="stat-value num">{{honba}}</text>
    </view>
    <view class="round-stat">
      <text class="stat-label">状态</text>
      <text class="stat-value">{{statusText}}</text>
    </view>
  </view>

  <view class="section action-grid">
    <button class="felt-main" bindtap="onWinTap">和牌</button>
    <button class="felt-sub" bindtap="onDrawTap">流局</button>
    <button class="felt-sub" bindtap="onRiichiTap">立直</button>
    <button class="felt-sub" bindtap="onPhotoTap">拍照识别</button>
    <button class="felt-ghost" bindtap="onUndoTap">撤销上一步</button>
    <button class="felt-ghost" bindtap="onSettlementTap">查看结算</button>
  </view>

  <view class="section">
    <button class="finish-button" bindtap="onFinishTap">终局结算</button>
  </view>

  <view class="section panel">
    <view class="section-title">事件履历</view>
    <view wx:if="{{events.length === 0}}" class="empty">暂无事件</view>
    <block wx:for="{{events}}" wx:key="id">
      <view class="event-item">
        <view class="event-main">
          <text class="event-type t-{{item.type}}">{{item.typeText}}</text>
          <image
            wx:if="{{item.actorAvatarFileId}}"
            class="event-avatar"
            src="{{item.actorAvatarFileId}}"
            mode="aspectFill"
          />
          <view wx:else class="event-avatar avatar-fallback">{{item.actorAvatarText}}</view>
          <text class="event-actor">{{item.actorNickName}}</text>
          <text class="event-time">{{item.createdText}}</text>
        </view>
        <view class="event-deltas">{{item.deltaText}}</view>
      </view>
    </block>
  </view>

  <view wx:if="{{eventPanelVisible}}" class="modal-mask">
    <view class="event-panel">
      <view class="panel-title">{{eventTypeText}}</view>
      <block wx:for="{{deltaInputs}}" wx:key="openid">
        <view class="delta-row">
          <view>
            <view class="delta-player">{{item.seatText}} {{item.nickName}}</view>
            <view class="delta-hint">正数加点，负数扣点</view>
          </view>
          <input
            class="delta-input"
            type="number"
            value="{{item.value}}"
            data-openid="{{item.openid}}"
            bindinput="onDeltaInput"
          />
        </view>
      </block>

      <view class="setting-row">
        <text>供托变化</text>
        <input class="small-input" type="number" value="{{riichiStickDelta}}" bindinput="onRiichiDeltaInput" />
      </view>
      <view class="setting-row">
        <text>本场变化</text>
        <input class="small-input" type="number" value="{{honbaDelta}}" bindinput="onHonbaDeltaInput" />
      </view>
      <view class="setting-row">
        <text>推进局数</text>
        <switch checked="{{advanceRound}}" color="#176b5b" bindchange="onAdvanceRoundChange" />
      </view>
      <textarea
        class="note-input"
        maxlength="80"
        placeholder="备注，可留空"
        value="{{note}}"
        bindinput="onNoteInput"
      />

      <view class="button-row panel-actions">
        <button class="secondary-button" bindtap="onCancelEvent">取消</button>
        <button class="primary-button" loading="{{submitting}}" bindtap="onSubmitEvent">记录</button>
      </view>
    </view>
  </view>
</view>
