<view class="page capture-page">
  <view class="panel capture-header">
    <view>
      <view class="room-code">房间 {{roomCode || "------"}}</view>
      <view class="round-line">{{roundText}} {{honba}}本场 / 供托 {{riichiSticks}}</view>
    </view>
    <view class="mode-badge">{{mode === "3p" ? "三麻" : "四麻"}}</view>
  </view>

  <view class="section panel">
    <view class="section-title">图片识别</view>
    <view class="button-row action-row">
      <button class="primary-button" bindtap="onOpenCameraCapture">拍照</button>
      <button class="secondary-button" bindtap="onChooseImage">相册</button>
      <button class="secondary-button" bindtap="onManualOnlyTap">手动录入</button>
    </view>
    <view class="hint-line">拍摄建议：按双框分别对准手牌与宝牌指示牌，光线充足、避免反光</view>
    <image wx:if="{{imageTempPath}}" class="photo-preview" src="{{imageTempPath}}" mode="aspectFill" />
    <view class="status-line">{{recognizeState}}</view>
    <view wx:if="{{recognizeError}}" class="error-line">{{recognizeError}}</view>
  </view>

  <view class="section panel">
    <view class="section-heading">
      <view class="section-title">牌面修正</view>
      <button class="mini-button" bindtap="onSortTiles">理牌</button>
    </view>
    <view wx:if="{{tiles.length === 0}}" class="empty">暂无牌面，可点选下方牌键录入或先识别图片</view>
    <view class="tile-grid">
      <block wx:for="{{tiles}}" wx:key="renderKey">
        <view
          class="tile-cell {{item.isWinning ? 'winning' : ''}}"
          data-index="{{index}}"
          bindtap="onTileTap"
        >
          <image class="tile-cell-img" src="{{item.src}}" mode="aspectFit" />
          <text wx:if="{{item.isWinning}}" class="winning-mark">和</text>
        </view>
      </block>
    </view>
    <view class="keyboard-status">已录入 {{tiles.length}} 张 · 点牌可修改，红框为和牌张</view>
    <view wx:if="{{tiles.length > 0}}" class="sequence-line num">{{handSequence}}</view>
    <tile-keyboard bind:tap="onHandKeyboardTap" bind:delete="onHandKeyboardDelete" />

    <view class="sub-section">
      <view class="section-heading">
        <view class="sub-title">副露</view>
        <button class="mini-button" bindtap="onAddMeld">新增副露</button>
      </view>
      <view wx:if="{{melds.length === 0}}" class="muted-line">无副露</view>
      <block wx:for="{{melds}}" wx:key="id">
        <view class="meld-row" data-index="{{index}}" bindtap="onEditMeld">
          <text class="meld-type">{{item.typeText}}</text>
          <view class="meld-tiles">
            <block wx:for="{{item.tileItems}}" wx:for-item="tile" wx:key="key">
              <tile-image code="{{tile.code}}" size="small" />
            </block>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="section panel">
    <view class="section-heading">
      <view class="section-title">场况</view>
      <button class="mini-button" bindtap="onYakuReferenceTap">役种表</button>
    </view>
    <view class="setting-row">
      <text>和牌者</text>
      <picker mode="selector" range="{{playerNames}}" value="{{winnerIndex}}" bindchange="onWinnerChange">
        <view class="picker-value">{{playerNames[winnerIndex] || "请选择"}}</view>
      </picker>
    </view>
    <view class="setting-row">
      <text>和牌方式</text>
      <view class="toggle-row">
        <button class="toggle-button {{winType === 'ron' ? 'active' : ''}}" data-type="ron" bindtap="onWinTypeTap">荣和</button>
        <button class="toggle-button {{winType === 'tsumo' ? 'active' : ''}}" data-type="tsumo" bindtap="onWinTypeTap">自摸</button>
      </view>
    </view>
    <view wx:if="{{winType === 'ron'}}" class="setting-row">
      <text>放铳者</text>
      <picker mode="selector" range="{{playerNames}}" value="{{loserIndex}}" bindchange="onLoserChange">
        <view class="picker-value">{{playerNames[loserIndex] || "请选择"}}</view>
      </picker>
    </view>
    <view class="setting-row">
      <text>场风</text>
      <text class="setting-value">{{prevalentWindText}}</text>
    </view>
    <view class="setting-row">
      <text>立直</text>
      <switch checked="{{riichi}}" color="#176b5b" bindchange="onRiichiChange" />
    </view>
    <view class="setting-row">
      <text>一发</text>
      <switch checked="{{ippatsu}}" color="#176b5b" bindchange="onIppatsuChange" />
    </view>
    <view class="field-block">
      <text class="label">宝牌指示牌</text>
      <view class="selected-tile-strip dora-strip">
        <block wx:if="{{doraIndicators.length > 0}}">
          <block wx:for="{{doraItems}}" wx:key="key">
            <view class="selected-tile" data-index="{{index}}" bindtap="onDoraTileTap">
              <tile-image code="{{item.code}}" size="medium" />
            </view>
          </block>
        </block>
        <text wx:if="{{doraIndicators.length === 0}}" class="strip-empty">未选择</text>
      </view>
      <tile-keyboard bind:tap="onDoraKeyboardTap" bind:delete="onDoraKeyboardDelete" />
    </view>
    <view wx:if="{{mode === '3p'}}" class="field-block">
      <text class="label">拔北数</text>
      <input class="input" type="number" value="{{nukiDora}}" bindinput="onNukiDoraInput" />
    </view>
    <button class="primary-button full-button" loading="{{scoring}}" bindtap="onScoreTap">算点预览</button>
  </view>

  <view wx:if="{{scorePreview}}" class="section panel">
    <view class="section-title">点数预览</view>
    <view class="score-main">{{scorePreview.valueText}}</view>
    <view class="score-sub">{{scorePreview.paymentText}}</view>
    <view class="yaku-line">{{scorePreview.yakuText}}</view>
    <block wx:for="{{scorePreview.deltaRows}}" wx:key="openid">
      <view class="delta-row">
        <text>{{item.label}}</text>
        <text class="{{item.valueClass}}">{{item.valueText}}</text>
      </view>
    </block>
    <button class="primary-button full-button" loading="{{applying}}" bindtap="onConfirmApply">确认落账</button>
  </view>

  <view wx:if="{{settlementCardVisible && settlementCard}}" class="celebration-mask">
    <view class="win-card {{settlementCard.limitLabel ? 'limit-win' : ''}}">
      <view wx:if="{{settlementCard.limitLabel}}" class="limit-badge">{{settlementCard.limitLabel}}</view>
      <view class="winner-block">
        <image
          wx:if="{{settlementCard.winnerAvatarFileId}}"
          class="winner-avatar"
          src="{{settlementCard.winnerAvatarFileId}}"
          mode="aspectFill"
        />
        <view wx:else class="winner-avatar avatar-fallback">{{settlementCard.winnerAvatarText}}</view>
        <view class="winner-name">{{settlementCard.winnerNickName}}</view>
      </view>
      <view class="win-score num">{{settlementCard.scoreText}}</view>
      <view class="win-detail">{{settlementCard.detailText}}</view>
      <view class="win-payment">{{settlementCard.paymentText}}</view>
      <view class="celebration-section">
        <block wx:for="{{settlementCard.yakuRows}}" wx:key="id">
          <view class="yaku-row">
            <text>{{item.name}}</text>
            <text class="yaku-value">{{item.valueText}}</text>
          </view>
        </block>
      </view>
      <view class="celebration-section">
        <block wx:for="{{settlementCard.deltaRows}}" wx:key="openid">
          <view class="delta-row celebration-delta-row">
            <text>{{item.label}}</text>
            <text class="{{item.valueClass}}">{{item.valueText}}</text>
          </view>
        </block>
      </view>
      <button class="primary-button return-room-button" bindtap="onReturnRoomTap">返回房间</button>
    </view>
  </view>

  <view wx:if="{{tileEditorVisible}}" class="modal-mask">
    <view class="editor-panel">
      <view class="panel-title">编辑牌</view>
      <view class="editor-tile-preview">
        <tile-image code="{{tileEditorValue}}" size="large" />
      </view>
      <tile-keyboard bind:tap="onTileEditorKeyboardTap" bind:delete="onTileEditorKeyboardDelete" />
      <view class="setting-row">
        <text>设为和牌张</text>
        <switch checked="{{tileEditorWinning}}" color="#176b5b" bindchange="onTileWinningChange" />
      </view>
      <button class="secondary-button full-button" bindtap="onMakePonMeld">用此牌创建碰副露</button>
      <view class="button-row panel-actions">
        <button class="danger-button" bindtap="onDeleteTile">删除</button>
        <button class="secondary-button" bindtap="onCancelTileEditor">取消</button>
        <button class="primary-button" bindtap="onSaveTileEditor">保存</button>
      </view>
    </view>
  </view>

  <view wx:if="{{meldEditorVisible}}" class="modal-mask">
    <view class="editor-panel">
      <view class="panel-title">编辑副露</view>
      <picker mode="selector" range="{{meldTypeTexts}}" value="{{meldTypeIndex}}" bindchange="onMeldTypeChange">
        <view class="picker-box">类型：{{meldTypeTexts[meldTypeIndex]}}</view>
      </picker>
      <view class="selected-tile-strip meld-editor-strip">
        <block wx:if="{{meldEditorTiles.length > 0}}">
          <block wx:for="{{meldEditorTiles}}" wx:key="*this">
            <view class="selected-tile" data-index="{{index}}" bindtap="onMeldEditorTileTap">
              <tile-image code="{{item}}" size="medium" />
            </view>
          </block>
        </block>
        <text wx:if="{{meldEditorTiles.length === 0}}" class="strip-empty">未选择副露牌</text>
      </view>
      <tile-keyboard bind:tap="onMeldKeyboardTap" bind:delete="onMeldKeyboardDelete" />
      <view class="button-row panel-actions">
        <button class="danger-button" bindtap="onDeleteMeld">删除</button>
        <button class="secondary-button" bindtap="onCancelMeldEditor">取消</button>
        <button class="primary-button" bindtap="onSaveMeld">保存</button>
      </view>
    </view>
  </view>
</view>
