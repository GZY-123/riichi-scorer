.capture-page {
  padding-bottom: 48rpx;
}

.capture-header,
.section-heading,
.setting-row,
.meld-row,
.delta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.capture-header {
  margin-bottom: 24rpx;
}

.room-code {
  color: #17322d;
  font-size: 36rpx;
  font-weight: 700;
}

.round-line,
.hint-line,
.muted-line {
  margin-top: 8rpx;
  color: #65736e;
  font-size: 24rpx;
}

.mode-badge {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #edf4f1;
  color: #176b5b;
  font-size: 24rpx;
  font-weight: 700;
}

.section-title {
  color: #17211f;
  font-size: 32rpx;
  font-weight: 700;
}

.sub-title {
  color: #17211f;
  font-size: 28rpx;
  font-weight: 700;
}

.action-row,
.full-button {
  margin-top: 24rpx;
}

.photo-preview {
  width: 100%;
  height: 360rpx;
  margin-top: 24rpx;
  border-radius: 14rpx;
  background: #e8e4d5;
}

.status-line {
  margin-top: 16rpx;
  color: #176b5b;
  font-size: 26rpx;
}

.error-line {
  margin-top: 8rpx;
  color: #8d2f2f;
  font-size: 24rpx;
}

.tile-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 24rpx;
}

.tile-cell {
  position: relative;
  aspect-ratio: 0.72;
  min-height: 116rpx;
  padding: 8rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #fdfbf4 0%, #f1ead5 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
    0 3rpx 6rpx rgba(31, 43, 39, 0.16);
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.tile-cell:active {
  transform: scale(0.97);
}

.tile-cell.winning {
  box-shadow:
    inset 0 0 0 3rpx var(--red),
    0 3rpx 6rpx rgba(31, 43, 39, 0.16);
}

.winning-mark {
  position: absolute;
  right: 6rpx;
  bottom: 4rpx;
  color: var(--red);
  font-size: 18rpx;
  font-weight: 700;
}

.keyboard-status {
  margin-top: 24rpx;
  color: #65736e;
  font-size: 24rpx;
}

tile-keyboard {
  display: block;
  margin-top: 16rpx;
}

.sub-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf1ef;
}

.meld-row {
  min-height: 72rpx;
  border-top: 1rpx solid #edf1ef;
}

.meld-type {
  flex: 0 0 auto;
  color: #176b5b;
  font-size: 26rpx;
  font-weight: 700;
}

.meld-tiles {
  display: flex;
  justify-content: flex-end;
  flex: 1;
  gap: 8rpx;
  min-width: 0;
  flex-wrap: wrap;
}

.setting-row {
  min-height: 88rpx;
  border-top: 1rpx solid #edf1ef;
  color: #17211f;
  font-size: 28rpx;
}

.setting-value,
.picker-value,
.picker-box {
  color: #176b5b;
  font-size: 28rpx;
}

.toggle-row {
  display: flex;
  gap: 16rpx;
}

.toggle-button {
  flex: 0 0 auto;
  width: fit-content !important;
  min-width: 130rpx;
  min-height: 64rpx;
  margin: 0 !important;
  padding: 0 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--line);
  background: #fdfcf8;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 60rpx;
}

.toggle-button.active {
  border-color: var(--felt);
  background: var(--felt);
  color: var(--ivory);
  font-weight: 600;
}

.field-block {
  margin-top: 16rpx;
}

.selected-tile-strip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 104rpx;
  padding: 16rpx;
  border: 1rpx solid var(--ivory-edge);
  border-radius: 14rpx;
  background: #fdfcf8;
  box-sizing: border-box;
  flex-wrap: wrap;
}

.dora-strip,
.meld-editor-strip {
  margin-bottom: 16rpx;
}

.selected-tile {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  border-radius: 9rpx;
  background: rgba(15, 83, 66, 0.06);
}

.selected-tile:active {
  transform: scale(0.96);
  opacity: 0.72;
}

.strip-empty {
  color: var(--muted);
  font-size: 26rpx;
}

.score-main {
  margin-top: 16rpx;
  color: #17322d;
  font-size: 38rpx;
  font-weight: 700;
}

.score-sub,
.yaku-line {
  margin-top: 10rpx;
  color: #5d6a66;
  font-size: 26rpx;
}

.delta-row {
  min-height: 72rpx;
  border-top: 1rpx solid #edf1ef;
  color: #17211f;
  font-size: 28rpx;
}

.delta-positive {
  color: var(--felt);
  font-weight: 700;
}

.delta-negative {
  color: var(--red);
  font-weight: 700;
}

.delta-neutral {
  color: var(--muted);
  font-weight: 700;
}

.celebration-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(12, 20, 18, 0.58);
  box-sizing: border-box;
}

.win-card {
  position: relative;
  width: 100%;
  max-height: 88vh;
  overflow: auto;
  padding: 40rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border: 4rpx solid transparent;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffdf7 0%, var(--ivory) 100%);
  box-shadow: 0 24rpx 64rpx rgba(6, 32, 25, 0.28);
  box-sizing: border-box;
  animation: winCardIn 300ms ease-out both;
}

.win-card.limit-win {
  border-color: var(--amber);
}

.limit-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  max-width: 220rpx;
  color: rgba(184, 134, 44, 0.2);
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1;
  text-align: right;
}

.winner-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.winner-avatar {
  width: 88rpx;
  height: 88rpx;
  overflow: hidden;
  border: 4rpx solid rgba(15, 83, 66, 0.12);
  border-radius: 50%;
  background: rgba(15, 83, 66, 0.1);
  box-sizing: border-box;
}

.avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--felt);
  font-size: 32rpx;
  font-weight: 700;
}

.winner-name {
  max-width: 100%;
  overflow: hidden;
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.win-score {
  margin-top: 24rpx;
  color: var(--felt-deep);
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
}

.win-detail {
  margin-top: 16rpx;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.win-payment {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 26rpx;
  text-align: center;
}

.celebration-section {
  margin-top: 32rpx;
  border-top: 1rpx solid var(--line);
}

.yaku-row,
.celebration-delta-row {
  min-height: 64rpx;
  border-top: 0;
}

.yaku-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  color: var(--ink);
  font-size: 28rpx;
}

.yaku-row + .yaku-row,
.celebration-delta-row + .celebration-delta-row {
  border-top: 1rpx solid rgba(31, 43, 39, 0.08);
}

.yaku-value {
  flex: 0 0 auto;
  color: var(--felt);
  font-weight: 700;
}

.return-room-button {
  margin-top: 32rpx;
}

@keyframes winCardIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(12, 20, 18, 0.42);
}

.editor-panel {
  width: 100%;
  max-height: 86vh;
  overflow: auto;
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.panel-title {
  margin-bottom: 24rpx;
  color: #17211f;
  font-size: 34rpx;
  font-weight: 700;
}

.editor-tile-preview {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 128rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--ivory-edge);
  border-radius: 16rpx;
  background: #fdfcf8;
}

.panel-actions {
  margin-top: 24rpx;
}

.tile-cell-img {
  width: 84%;
  height: 92%;
}

.sequence-line {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  word-break: break-all;
  line-height: 1.6;
}
