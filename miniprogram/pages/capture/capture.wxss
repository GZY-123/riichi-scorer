.capture-page {
  padding-bottom: 48rpx;
}

.capture-header,
.section-heading,
.setting-row,
.meld-row,
.delta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.capture-header {
  margin-bottom: 28rpx;
}

.room-code {
  color: #17322d;
  font-size: 36rpx;
  font-weight: 700;
}

.round-line,
.hint-line,
.muted-line {
  margin-top: 8rpx;
  color: #65736e;
  font-size: 24rpx;
}

.mode-badge {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 8rpx;
  background: #edf4f1;
  color: #176b5b;
  font-size: 24rpx;
  font-weight: 700;
}

.section-title {
  color: #17211f;
  font-size: 32rpx;
  font-weight: 700;
}

.sub-title {
  color: #17211f;
  font-size: 28rpx;
  font-weight: 700;
}

.action-row,
.full-button {
  margin-top: 22rpx;
}

.photo-preview {
  width: 100%;
  height: 360rpx;
  margin-top: 22rpx;
  border-radius: 14rpx;
  background: #e8e4d5;
}

.status-line {
  margin-top: 18rpx;
  color: #176b5b;
  font-size: 26rpx;
}

.error-line {
  margin-top: 8rpx;
  color: #8d2f2f;
  font-size: 24rpx;
}

.tile-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.tile-cell {
  position: relative;
  aspect-ratio: 0.72;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #fdfbf4 0%, #f1ead5 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.9),
    0 3rpx 6rpx rgba(31, 43, 39, 0.16);
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.tile-cell.winning {
  box-shadow:
    inset 0 0 0 3rpx var(--red),
    0 3rpx 6rpx rgba(31, 43, 39, 0.16);
}

.winning-mark {
  position: absolute;
  right: 6rpx;
  bottom: 4rpx;
  color: var(--red);
  font-size: 18rpx;
  font-weight: 700;
}

.manual-input {
  width: 100%;
  height: 140rpx;
  min-height: 0;
  margin-top: 22rpx;
  padding: 18rpx;
  border: 1rpx solid var(--ivory-edge);
  border-radius: 12rpx;
  background: #fdfcf8;
  box-sizing: border-box;
  color: var(--ink);
  font-size: 28rpx;
}

.sub-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf1ef;
}

.meld-row {
  min-height: 72rpx;
  border-top: 1rpx solid #edf1ef;
}

.meld-type {
  color: #176b5b;
  font-size: 26rpx;
  font-weight: 700;
}

.meld-tiles {
  color: #17211f;
  font-size: 28rpx;
}

.setting-row {
  min-height: 88rpx;
  border-top: 1rpx solid #edf1ef;
  color: #17211f;
  font-size: 28rpx;
}

.setting-value,
.picker-value,
.picker-box {
  color: #176b5b;
  font-size: 28rpx;
}

.toggle-row {
  display: flex;
  gap: 12rpx;
}

.toggle-button {
  flex: 0 0 auto;
  width: fit-content !important;
  min-width: 130rpx;
  min-height: 64rpx;
  margin: 0 !important;
  padding: 0 26rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--line);
  background: #fdfcf8;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 60rpx;
}

.toggle-button.active {
  border-color: var(--felt);
  background: var(--felt);
  color: var(--ivory);
  font-weight: 600;
}

.field-block {
  margin-top: 18rpx;
}

.score-main {
  margin-top: 18rpx;
  color: #17322d;
  font-size: 38rpx;
  font-weight: 700;
}

.score-sub,
.yaku-line {
  margin-top: 10rpx;
  color: #5d6a66;
  font-size: 26rpx;
}

.delta-row {
  min-height: 72rpx;
  border-top: 1rpx solid #edf1ef;
  color: #17211f;
  font-size: 28rpx;
}

.delta-positive {
  color: #176b5b;
  font-weight: 700;
}

.delta-negative {
  color: #8d2f2f;
  font-weight: 700;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(12, 20, 18, 0.42);
}

.editor-panel {
  width: 100%;
  max-height: 86vh;
  overflow: auto;
  padding: 32rpx 32rpx 40rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.panel-title {
  margin-bottom: 20rpx;
  color: #17211f;
  font-size: 34rpx;
  font-weight: 700;
}

.meld-input,
.panel-actions {
  margin-top: 22rpx;
}
