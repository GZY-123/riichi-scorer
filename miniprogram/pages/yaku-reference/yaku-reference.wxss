.yaku-reference-page {
  padding-bottom: 48rpx;
}

.intro-panel {
  margin-bottom: 24rpx;
}

.page-title {
  color: var(--felt-deep);
  font-size: 42rpx;
  font-weight: 800;
}

.rule-line {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.6;
}

.group-panel {
  padding-top: 28rpx;
  padding-bottom: 8rpx;
}

.group-title {
  margin-bottom: 12rpx;
  color: var(--felt-deep);
  font-size: 32rpx;
  font-weight: 800;
}

.yaku-item {
  padding: 22rpx 0;
  border-top: 1rpx solid var(--line);
}

.yaku-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.yaku-name-row {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
}

.yaku-name {
  min-width: 0;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
}

.menzen-badge {
  flex: 0 0 auto;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: rgba(184, 134, 44, 0.12);
  color: var(--amber);
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.4;
}

.yaku-han {
  flex: 0 0 auto;
  max-width: 220rpx;
  color: var(--felt);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: right;
}

.yaku-desc {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.55;
}

.example-scroll {
  width: 100%;
  margin-top: 14rpx;
  padding-bottom: 4rpx;
  white-space: nowrap;
}

.example-strip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.example-tile {
  flex: 0 0 auto;
  padding: 4rpx;
  border: 2rpx solid transparent;
  border-radius: 8rpx;
  background: #fdfcf8;
}

.example-tile.winning {
  border-color: var(--red);
}
