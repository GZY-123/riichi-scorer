.tile-keyboard {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid var(--ivory-edge, #e3dcc4);
  border-radius: 16rpx;
  background: var(--ivory, #fbf8ef);
  box-sizing: border-box;
}

.keyboard-row {
  display: grid;
  grid-template-columns: repeat(9, minmax(0, 1fr));
  gap: 6rpx;
}

.keyboard-row + .keyboard-row {
  margin-top: 8rpx;
}

.keyboard-key {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 68rpx;
  border: 1rpx solid var(--ivory-edge, #e3dcc4);
  border-radius: 8rpx;
  background: linear-gradient(180deg, #fffdf7 0%, var(--ivory-deep, #f3edda) 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.88),
    0 2rpx 5rpx rgba(31, 43, 39, 0.12);
  box-sizing: border-box;
  transition: transform 80ms ease, filter 80ms ease, opacity 80ms ease;
}

.keyboard-key-active {
  transform: scale(0.94);
  opacity: 0.76;
}

.keyboard-tool-row {
  align-items: center;
}

.keyboard-delete {
  grid-column: span 2;
  background: var(--felt, #0f5342);
  border-color: var(--felt-deep, #0a3d31);
  box-shadow: 0 2rpx 6rpx rgba(6, 32, 25, 0.22);
}

.keyboard-delete-text {
  color: var(--ivory, #fbf8ef);
  font-size: 24rpx;
  font-weight: 700;
}
