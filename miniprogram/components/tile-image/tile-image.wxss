.tile-image-shell {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex: 0 0 auto;
}

.tile-image-small {
  width: 44rpx;
  height: 59rpx;
  border-radius: 5rpx;
}

.tile-image-medium {
  width: 64rpx;
  height: 85rpx;
  border-radius: 7rpx;
}

.tile-image-large {
  width: 80rpx;
  height: 107rpx;
  border-radius: 8rpx;
}

.tile-image-img {
  display: block;
  width: 100%;
  height: 100%;
}
