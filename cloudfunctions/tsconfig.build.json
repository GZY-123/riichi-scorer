{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "types": [],
    "rootDir": ".",
    "outDir": ".build",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["**/*.test.ts", ".build/**", "**/dist/**", "**/engine-lib/**", "**/node_modules/**"]
}
