{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2020", "DOM"],
    "types": ["miniprogram-api-typings"]
  },
  "include": [
    "miniprogram/**/*.ts",
    "miniprogram/**/*.d.ts",
    "cloudfunctions/**/*.ts",
    "cloudfunctions/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "miniprogram_npm",
    "**/*.test.ts"
  ]
}
